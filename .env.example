# Supabase project URL for browser/client usage (added in a future commit).
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon/public key for browser/client usage (added in a future commit).
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

# Supabase service role key for server-side admin tasks; server-only, never expose to client (added in a future commit).
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Base URL for the n8n automation instance (added in a future commit).
N8N_BASE_URL="https://n8n.example.com"

# API key used by server-side workflows to call n8n (added in a future commit).
N8N_API_KEY="replace-with-n8n-api-key"

# Shared secret for n8n -> backend webhook auth, server-only.
WEBHOOK_SHARED_SECRET="replace-with-webhook-shared-secret"

# Vercel Cron auth, injected automatically as Bearer token by Vercel, server-only.
CRON_SECRET="replace-with-vercel-cron-secret"
